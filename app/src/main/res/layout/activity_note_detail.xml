<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F3FF"
    android:orientation="vertical">

    <!-- TOOLBAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/back_btn_bg"
            android:src="@android:drawable/ic_media_previous"
            android:padding="8dp"
            app:tint="#6C5CE7" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Not Düzenle"
            android:textColor="#1A1A2E"
            android:textSize="17sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:backgroundTint="#6C5CE7"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:text="Kaydet"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            app:cornerRadius="10dp" />

    </LinearLayout>

    <!-- Renk Seçici -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Renk:"
            android:textColor="#9E9E9E"
            android:textSize="12sp"
            android:layout_marginEnd="10dp" />

        <View
            android:id="@+id/colorDotPurple"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:background="@drawable/color_dot_purple"
            android:layout_marginEnd="8dp" />

        <View
            android:id="@+id/colorDotTeal"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:background="@drawable/color_dot_teal"
            android:layout_marginEnd="8dp" />

        <View
            android:id="@+id/colorDotPink"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:background="@drawable/color_dot_pink"
            android:layout_marginEnd="8dp" />

        <View
            android:id="@+id/colorDotAmber"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:background="@drawable/color_dot_amber"
            android:layout_marginEnd="8dp" />

        <View
            android:id="@+id/colorDotGreen"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:background="@drawable/color_dot_green"
            android:layout_marginEnd="8dp" />

    </LinearLayout>

    <!-- İnce ayırıcı çizgi -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0EEFF" />

    <!-- NOT İÇERİĞİ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp">

        <EditText
            android:id="@+id/etTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@null"
            android:hint="Başlık Yazınız..."
            android:inputType="text"
            android:textColor="#1A1A2E"
            android:textColorHint="#C4BEE8"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingBottom="12dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@android:drawable/ic_menu_today"
                android:layout_marginEnd="6dp"
                app:tint="#A29BFE" />

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="24 Mayıs 2026"
                android:textColor="#B0AAC8"
                android:textSize="12sp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0EEFF"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etContent"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@null"
            android:gravity="start|top"
            android:hint="Notunuzu buraya giriniz..."
            android:inputType="textMultiLine"
            android:textColor="#3D3560"
            android:textColorHint="#C4BEE8"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.6" />

    </LinearLayout>

    <!-- ALT TOOLBAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="4dp">

        <ImageButton
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_edit"
            android:padding="8dp"
            app:tint="#A29BFE" />

        <ImageButton
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_add"
            android:padding="8dp"
            app:tint="#A29BFE" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnDelete"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:backgroundTint="#FFF0F0"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:text="Sil"
            android:textColor="#E74C3C"
            android:textSize="13sp"
            android:textStyle="bold"
            app:cornerRadius="10dp" />

    </LinearLayout>

</LinearLayout>